# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model to use (default: claude-sonnet-4-20250514)
MODEL=claude-sonnet-4-20250514

# Optional: max agent steps per task (default: 50)
MAX_STEPS=50

# Optional: browser viewport size
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=900

# Optional: run browser without UI (default: false)
HEADLESS=false

# Optional: screenshot quality 1-100 (default: 70)
SCREENSHOT_QUALITY=70

# Optional: max context exchanges before trimming (default: 12)
MAX_CONTEXT_PAIRS=12
